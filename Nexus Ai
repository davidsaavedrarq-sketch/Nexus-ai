import os
import json
import datetime
import hashlib
import random
import re


class Nexus:
    """Nexus AI — a helpful conversational assistant."""

    def __init__(self, name="Nexus", version="1.0.0"):
        self.name = name
        self.version = version
        self.memory = []
        self.knowledge_base = {}
        self.user_preferences = {}

    def greet(self):
        return f"Hello, I'm {self.name} v{self.version}. How can I help you today?"

    def process_input(self, user_input):
        """Main entry point — understand and respond to user input."""
        self._remember(user_input, role="user")

        response = self._generate_response(user_input)

        self._remember(response, role="assistant")
        return response

    def _remember(self, text, role="user"):
        self.memory.append({
            "role": role,
            "text": text,
            "timestamp": datetime.datetime.now().isoformat()
        })

    def _generate_response(self, user_input):
        """Generate a response based on input patterns."""
        text = user_input.lower().strip()

        # Greetings
        if any(word in text for word in ("hello", "hi", "hey", "sup")):
            return self._greet_response()

        # How are you
        if "how are you" in text:
            return "I'm running smoothly! Thanks for asking. How can I assist you?"

        # Name / identity
        if "your name" in text or "who are you" in text:
            return (
                f"My name is {self.name}. "
                "I'm a conversational AI built to help with questions, tasks, and creative work."
            )

        # Time / date
        if "time" in text or "date" in text or "what day" in text:
            now = datetime.datetime.now()
            return (
                f"The current time is {now.strftime('%I:%M %p')} "
                f"on {now.strftime('%A, %B %d, %Y')}."
            )

        # Help
        if "help" in text or "what can you do" in text:
            return self._help_response()

        # Math
        if any(op in text for op in ("+", "-", "*", "/", "plus", "minus", "times", "divided")):
            return self._solve_math(user_input)

        # Joke
        if "joke" in text or "funny" in text:
            return self._tell_joke()

        # Farewell
        if any(word in text for word in ("bye", "goodbye", "exit", "quit")):
            return "Goodbye! Feel free to come back anytime."

        # Fallback — learn from unknown input
        return self._learn_and_respond(user_input)

    def _greet_response(self):
        greetings = (
            "Hey there! What's on your mind?",
            "Hello! Ready to help.",
            "Hi! How can I assist you today?"
        )

        return random.choice(greetings)

    def _help_response(self):
        return (
            f"I can do quite a bit:\n"
            f" • Answer questions and have conversations\n"
            f" • Solve math problems\n"
            f" • Tell jokes\n"
            f" • Tell you the time and date\n"
            f" • Remember things you tell me (in this session)\n"
            f" • Learn new information\n\n"
            f"Just type naturally and I'll do my best!"
        )

def _solve_math(self, expression):
        """Simple math evaluator."""
        # Clean up words
        expr = expression.lower()
        expr = expr.replace("plus", "+")
        expr = expr.replace("minus", "-")
        expr = expr.replace("times", "*")
        expr = expr.replace("divided by", "/")
        expr = expr.replace("x", "*")
        expr = expr.replace("÷", "/")

        # Extract the math part
        match = re.search(r"[0-9+\-*/(). ]+", expr)

        if match:
            try:
                result = eval(match.group())
                return f"The answer is {result}."
            except Exception:
                return "I couldn't parse that math problem. Try something like '5 + 3'."

        return "I couldn't find a math expression in that."

    def _tell_joke(self):
        jokes = (
            "Why don't scientists trust atoms? Because they make up everything!",
            "What do you call a fake noodle? An impasta!",
            "Why did the AI cross the road? To optimize the other side.",
            "I told my computer I needed a break... now it won't stop sending me vacation ads."
        )

        return random.choice(jokes)

    def _learn_and_respond(self, user_input):
        """When Nexus doesn't recognize the input, learn from it."""

        # Store unknown input for potential learning
        if (
            "remember" in user_input.lower()
            or "my name is" in user_input.lower()
        ):
            return self._store_fact(user_input)

        return (
            "I'm not sure how to answer that yet, but I've noted what you said. "
            "Tell me 'help' to see what I can do, or teach me something by saying "
            "'remember that fact'."
        )

    def _store_fact(self, user_input):
        text = user_input.lower()

        if "my name is" in text:
            name = (
                text.split("my name is")[-1]
                .strip()
                .strip(".!,")
                .title()
            )

            self.user_preferences["name"] = name
            return f"Nice to meet you, {name}! I'll remember that."

        if "remember" in text:
            fact = (
                text.replace("remember", "")
                .replace("that", "")
                .strip()
            )

            fact_id = hashlib.md5(fact.encode()).hexdigest()[:8]
            self.knowledge_base[fact_id] = fact

            return f"Got it! I've stored: '{fact}'"

        return "Tell me something like 'remember that I like pizza'."

    def show_memory(self):
        """Display conversation history (for debugging)."""

        if not self.memory:
            return "No conversation history yet."

        lines = []

        for entry in self.memory:
            lines.append(f"{entry['role']}: {entry['text']}")

        return "\n".join(lines)

    def save_session(self, filepath="nexus_session.json"):
        """Save conversation to a file."""

        data = {
            "name": self.name,
            "version": self.version,
            "memory": self.memory,
            "knowledge_base": self.knowledge_base,
            "user_preferences": self.user_preferences
        }

        with open(filepath, "w") as f:
            json.dump(data, f, indent=2)

        return f"Session saved to {filepath}"

    def load_session(self, filepath="nexus_session.json"):
        """Load a saved session."""

        if os.path.exists(filepath):
            with open(filepath, "r") as f:
                data = json.load(f)

            self.memory = data.get("memory", [])
            self.knowledge_base = data.get("knowledge_base", {})
            self.user_preferences = data.get("user_preferences", {})

            return f"Session loaded from {filepath}"

        return "No saved session found."

# ─── Interactive CLI ──────────────────────────────────────────────────────────

def main():
    nexus = Nexus()

    print(nexus.greet())
    print()

    while True:
        try:
            user_input = input("You: ").strip()

            if not user_input:
                continue

            # Special commands
            if user_input.lower() in ("/memory", "/history"):
                print(nexus.show_memory())
                continue

            if user_input.lower() == "/save":
                print(nexus.save_session())
                continue

            if user_input.lower() == "/load":
                print(nexus.load_session())
                continue

            if user_input.lower() in ("/exit", "/quit"):
                print("Nexus: Goodbye!")
                break

            response = nexus.process_input(user_input)
            print(f"{nexus.name}: {response}")

        except KeyboardInterrupt:
            print("\nNexus: Goodbye!")
            break

        except Exception as e:
            print(f"Something went wrong: {e}")


if __name__ == "__main__":
    main()
